numbers = [1] * 1_000_000
numbers[0] = 0
numbers[1] = 0

for n in range(2, len(numbers)):
    if numbers[n] == 1:
        for i in range(n+n, len(numbers), n):
            numbers[i] = 0
primes = [i for i, j in enumerate(numbers) if j]

def generate_primes(x):
    
    answer = []
    for p in primes:
        if p > x:
            return answer
        answer.append(p)
